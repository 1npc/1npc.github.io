@misc{meng2026eviact,
    title = {{EviACT}: An Evidence-to-Action Framework for Agentic Program Repair},
    author = {Meng, Qianru and Zhang, Xiao and Ren, Zhaochun and Visser, Joost},
    year = {2026},
    month = may,
    day = {26},
    eprint = {2605.27238},
    archivePrefix = {arXiv},
    primaryClass = {cs.SE},
    url = {https://arxiv.org/abs/2605.27238},
    selected = {true},
    abstract = {LLM-based agents have moved automated program repair from fixed-context patch generation to interactive repository-level repair. EviACT coordinates three evidence-driven guardrails across repair stages: a retrieval scaffold, a compile gate, and a test-driven gate.}
